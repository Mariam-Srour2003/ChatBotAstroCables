# Copy this file to .env and fill in your values.
# Get a free Groq API key at: https://console.groq.com

# ── LLM provider ─────────────────────────────────────────────────────────────
# "groq"    → fast cloud API, free tier, ~2 s per reply  ✅ recommended
# "gpt4all" → local model, no internet, but very slow on CPU

# ── Groq settings (only used when LLM_PROVIDER=groq) ─────────────────────────


# Model options (free on Groq):
#   llama-3.1-8b-instant   ← fastest
#   llama-3.3-70b-versatile ← best quality
#   mixtral-8x7b-32768     ← good balance





LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_REWRITE_MODEL=llama-3.1-8b-instant

EMAIL_FROM=your_email_here
EMAIL_TO=your_email_here
# Optional 2nd recipient - leave blank to send to EMAIL_TO only
EMAIL_TO_2=
EMAIL_PASS=your_email_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Leave WHATSAPP_TOKEN blank to keep the WhatsApp channel switched off.
# Full walkthrough: README → "WhatsApp channel".

# Meta → your app → WhatsApp → API Setup → "Temporary access token"
# (expires every 24 h — replace with a permanent System User token for production)
WHATSAPP_TOKEN=

# Same screen, under "From" — the Phone number ID, NOT the phone number itself
WHATSAPP_PHONE_NUMBER_ID=

# Same screen — "WhatsApp Business Account ID". Needed by
# `python whatsapp_test.py subscribe`, which makes Meta deliver webhooks to
# YOUR app. Without that step messages go to Meta's demo app and never arrive.
WHATSAPP_WABA_ID=

# Any random string you invent. Type the identical value into
# Meta → Configuration → Edit webhook → "Verify token"
WHATSAPP_VERIFY_TOKEN=astro_verify_change_me

# Meta → App settings → Basic → App secret. Proves callbacks really come from
# Meta. Optional locally; set it before going live.
WHATSAPP_APP_SECRET=
